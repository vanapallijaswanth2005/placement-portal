# ------------------------------------------------------------------------------
# Placement Portal - Environment Configuration Template
# ------------------------------------------------------------------------------
# INSTRUCTIONS:
# 1. Copy this file and rename it to `.env`
# 2. Fill in the values below for your production environment
# 3. DO NOT commit your actual `.env` file to version control (ensure it is in .gitignore)
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# Database Configuration
# ------------------------------------------------------------------------------
DB_URL=jdbc:mysql://localhost:3306/placement_portal
DB_USERNAME=root
DB_PASSWORD=your_secure_db_password_here

# ------------------------------------------------------------------------------
# Security Configuration
# ------------------------------------------------------------------------------
# A strong secret key used for signing JWT tokens. Use at least 32 random characters.
JWT_SECRET=your_super_secret_jwt_key_here_must_be_at_least_32_chars

# ------------------------------------------------------------------------------
# Email Configuration (SMTP)
# ------------------------------------------------------------------------------
# Used to send welcome emails, password reset links, and application updates.
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password_here

# ------------------------------------------------------------------------------
# Admin Seeding (First-time setup)
# ------------------------------------------------------------------------------
APP_SEED_ADMIN_ENABLED=true
APP_SEED_ADMIN_USERNAME=admin
APP_SEED_ADMIN_PASSWORD=Admin@123
APP_SEED_ADMIN_EMAIL=admin@youruniversity.edu

# ------------------------------------------------------------------------------
# File Storage Configuration (Optional)
# ------------------------------------------------------------------------------
# Set to 'local' for storing resumes on disk, or 's3' for AWS S3.
STORAGE_PROVIDER=local

# If using s3, provide the following:
AWS_BUCKET_NAME=your_s3_bucket_name
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
