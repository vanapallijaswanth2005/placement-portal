# Copy this file to .env in the project root and fill in your values.
# Spring Boot loads .env automatically via spring-dotenv (no BOM / UTF-8 only).
DB_URL=jdbc:mysql://localhost:3306/placement_portal
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

JWT_SECRET=replace-with-a-secret-at-least-32-characters-long

MAIL_USERNAME=
MAIL_PASSWORD=

# Optional admin bootstrap (local/dev only)
APP_SEED_ADMIN_ENABLED=true
APP_SEED_ADMIN_USERNAME=admin
APP_SEED_ADMIN_PASSWORD=choose-a-strong-password
APP_SEED_ADMIN_EMAIL=admin@placement.local
